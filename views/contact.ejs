<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guestbook</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="icon" type="image/x-icon" href="/styles/favicon.ico">
</head>
<body>
    <%- include('partials/nav') %>
    <main class="container">
    <form class="contact-form" id="guestbook-form" action="/submit" method="POST">
        <h2>Contact Form</h2>

        <div class="grid-container">
            <div class="form-group">
                <label for="first-name">First Name</label>
                <input type="text" id="first-name" name="first-name" required>
            </div>
            <div class="form-group">
                <label for="last-name">Last Name</label>
                <input type="text" id="last-name" name="last-name" required>
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required>
            </div>
            <div class="form-group">
                <label for="linkedin">LinkedIn URL</label>
                <input type="url" id="linkedin" name="linkedin">
            </div>
        </div>

        <div class="mid-grid">
            <div class="form-group">
                <label for="meet">How did we meet?</label>
                <select id="meet" name="meet" onchange="toggleOther(this.value)">
                    <option value="">Please select</option>
                    <option value="meetup">Meetup</option>
                    <option value="job-fair">Job Fair</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="form-group" id="other-specify-group" style="display: none;">
                <label for="other">Other (please specify)</label>
                <input type="text" id="other" name="other">
            </div>
        </div>

        <div class="radio-group">
            <p>Preferred Email Format:</p>
            <input type="radio" id="html" name="format" value="html" checked>
            <label for="html">HTML</label>
            <input type="radio" id="text" name="format" value="text">
            <label for="text">Text</label>
        </div>

        <div class="form-group">
            <label for="comments">Comments</label>
            <textarea id="comments" name="comments" rows="5" placeholder="Leave me a message..."></textarea>
        </div>

        <div class="checkbox-group">
            <input type="checkbox" id="mailing-list" name="mailing-list">
            <label for="mailing-list">Please add me to your mailing list</label>
        </div>

        <button type="submit" class="submit-btn">Submit</button>
    </form>
    <footer>
        <p>View my code on <a href="https://github.com/tonymythical/portfolio">GitHub</a></p>
    </footer>
</main>
<script src="./../public/js/script.js">
    function toggleOther(val) {
        const otherGroup = document.getElementById('other-specify-group');
        otherGroup.style.display = (val === 'other') ? 'block' : 'none';
    }
</script>
</body>
</html>
