<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin - Guestbook</title>
    <link rel="stylesheet" href="/styles/style.css">
    <link rel="icon" type="image/x-icon" href="/styles/favicon.ico">
</head>
<body>
    <%- include('partials/nav') %>
    <main class="container">
        <h2>Guestbook Submissions</h2>

        <% if (users.length === 0) { %>
            <p style="text-align: center;">No contacts to display yet.</p>
        <% } else { %>
            <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
                <thead>
                    <tr style="background-color: #2c3e50; color: white;">
                        <th style="padding: 10px; border: 1px solid #ddd;">Date</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Name</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Email</th>
                        <th style="padding: 10px; border: 1px solid #ddd;">Met Via</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td style="padding: 10px; border: 1px solid #ddd;"><%= user.timestamp %></td>
                            <td style="padding: 10px; border: 1px solid #ddd;"><%= user.firstName %> <%= user.lastName %></td>
                            <td style="padding: 10px; border: 1px solid #ddd;"><%= user.email %></td>
                            <td style="padding: 10px; border: 1px solid #ddd;"><%= user.howWeMet %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </main>
</body>
</html>